# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# ── סביבת טיוטה לוקאלית (design sandbox) ─────────────────────────────────────
# כל מה שתחת app/draft/ הוא לניסויים עיצוביים לוקאליים בלבד. מתעלמים ממנו בכוונה
# כדי שה-auto-commit → push → Vercel לעולם לא יתפוס אותו. שום דבר כאן לא עולה
# לורסל. אם בכל זאת תרצה לקדם ניסוי — הוסף אותו ידנית עם `git add -f`.
/app/draft/

# gemini pipeline output (PRD §7) — keep the dir, ignore generated artwork
/public/generated/*
!/public/generated/.gitkeep
# ...חוץ מהתמונות שהאתר תלוי בהן (רקע Hero + wordmark + רקע אמצע/תחתית) — חייבות להיכנס ל-git לדיפלוי
!/public/generated/hero.png
!/public/generated/wordmark.png
!/public/generated/background.png
# אובייקטים מצוירים לרקע אמצע/תחתית (sprites שקופים) — חייבים להיכנס ל-git לדיפלוי
!/public/generated/obj-*.png

# typescript
*.tsbuildinfo
next-env.d.ts
